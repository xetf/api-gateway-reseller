generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
  SUSPENDED
  TRIAL
  RISK_REVIEW
}

enum ApiKeyStatus {
  ACTIVE
  DISABLED
  REVOKED
}

enum WalletTransactionType {
  RECHARGE
  CHARGE
  REFUND
  ADJUST
}

enum ApiRequestStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ApiRequestResultType {
  PROXIED_SUCCESS
  UPSTREAM_ERROR
  GATEWAY_NOTICE
  IP_BAN
  RATE_LIMITED
  INSUFFICIENT_BALANCE
  MANUAL_TERMINATED
  AUTO_TERMINATED
  BILLING_ERROR
  CLIENT_CLOSED
  GATEWAY_ERROR
}

enum UpstreamProviderStatus {
  ACTIVE
  DISABLED
}

enum RedeemCodeStatus {
  ACTIVE
  DISABLED
}

enum AccessTierStatus {
  ACTIVE
  DISABLED
}

enum DedicatedRouteTargetType {
  USER
  API_KEY
  IP
}

enum DedicatedRouteRuleStatus {
  ACTIVE
  DISABLED
}

model AccessTier {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  status      AccessTierStatus @default(ACTIVE)
  sortOrder   Int              @default(100)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users                User[]
  apiKeys              ApiKey[]
  modelPools           ModelPool[]
  apiRequests          ApiRequest[]
  dedicatedRouteRules  DedicatedRouteRule[]
  ipAccessTierRules    IpAccessTierRule[]
  redeemCodes          RedeemCode[]

  @@index([status, sortOrder])
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String?    @unique
  name         String?
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  statusReason String?
  allowedModels String[]   @default([])
  rateLimitPerMinute Int    @default(0)
  concurrencyLimit   Int    @default(0)
  charityEnabled     Boolean @default(false)
  charityDisplayName String?
  charityKey         String?
  charityIpRateLimitEnabled Boolean @default(false)
  charityIpRateLimitPerMinute Int @default(0)
  tierId       String?
  tokenVersion       Int    @default(0)
  lastLoginAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tier               AccessTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  apiKeys            ApiKey[]
  wallet             Wallet?
  walletTransactions WalletTransaction[]
  apiRequests        ApiRequest[]
  redeemRedemptions  RedeemCodeRedemption[]
  dedicatedRouteRules DedicatedRouteRule[] @relation("DedicatedRouteRuleUser")
  createdModelPrices ModelPrice[]
  loginLogs          LoginLog[]

  @@index([tierId])
  @@index([status])
}

model ApiKey {
  id                 String       @id @default(cuid())
  userId             String
  name               String
  keyHash            String       @unique
  keyPrefix          String
  keySecret          String?
  status             ApiKeyStatus @default(ACTIVE)
  allowedModels      String[]     @default([])
  rateLimitPerMinute Int          @default(60)
  dailyLimitUsd      Decimal?     @db.Decimal(18, 8)
  totalLimitUsd      Decimal?     @db.Decimal(18, 8)
  concurrencyLimit   Int          @default(0)
  noticeEnabled      Boolean      @default(false)
  noticeText         String?
  tags               String[]     @default([])
  disabledReason     String?
  disabledAt         DateTime?
  ipWhitelist        String[]     @default([])
  tierId             String?
  expiresAt          DateTime?
  lastUsedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tier        AccessTier?  @relation(fields: [tierId], references: [id], onDelete: SetNull)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiRequests ApiRequest[]
  dedicatedRouteRules DedicatedRouteRule[] @relation("DedicatedRouteRuleApiKey")

  @@index([userId])
  @@index([keyPrefix])
  @@index([tierId])
  @@index([status, disabledAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(18, 8)
  reservedBalance Decimal @default(0) @db.Decimal(18, 8)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id            String                @id @default(cuid())
  userId        String
  requestId     String?
  type          WalletTransactionType
  source        String                @default("UNKNOWN")
  amount        Decimal               @db.Decimal(18, 8)
  balanceBefore Decimal               @db.Decimal(18, 8)
  balanceAfter  Decimal               @db.Decimal(18, 8)
  remark        String?
  metadata      Json?
  createdAt     DateTime              @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiRequest ApiRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([requestId])
  @@index([source, createdAt])
}

model ApiRequest {
  id                String           @id @default(cuid())
  traceCode         String           @unique @default(dbgenerated("('REQ-DB-' || upper(substr(md5(((random())::text || (clock_timestamp())::text)), 1, 16)))"))
  userId            String
  apiKeyId          String?
  upstreamProviderKeyId String?
  upstreamProvider  String
  model             String
  reasoningEffort   String?
  reasoningEffortActual String?
  endpoint          String
  method            String
  status            ApiRequestStatus @default(PENDING)
  resultType        ApiRequestResultType?
  httpStatus        Int?
  inputTokens       Int              @default(0)
  cachedInputTokens Int              @default(0)
  outputTokens      Int              @default(0)
  totalTokens       Int              @default(0)
  upstreamCostUsd   Decimal          @default(0) @db.Decimal(18, 8)
  chargedAmountUsd  Decimal          @default(0) @db.Decimal(18, 8)
  reservedAmountUsd Decimal          @default(0) @db.Decimal(18, 8)
  latencyMs         Int?
  firstTokenLatencyMs Int?
  errorMessage      String?
  upstreamRequestId String?
  clientIp          String?
  userAgent         String?
  requestBody       Json?
  responseUsage     Json?
  accessTierId      String?
  dedicatedRouteRuleId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey             ApiKey?             @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  upstreamProviderKey UpstreamProviderKey? @relation(fields: [upstreamProviderKeyId], references: [id], onDelete: SetNull)
  accessTier         AccessTier?         @relation(fields: [accessTierId], references: [id], onDelete: SetNull)
  dedicatedRouteRule DedicatedRouteRule?  @relation(fields: [dedicatedRouteRuleId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([upstreamProviderKeyId, createdAt])
  @@index([accessTierId, createdAt])
  @@index([dedicatedRouteRuleId, createdAt])
  @@index([status, createdAt])
  @@index([resultType, createdAt])
  @@index([model, createdAt])
}

model AdminAuditLog {
  id             String   @id @default(cuid())
  adminUserId    String?
  adminEmail     String?
  action         String
  method         String
  path           String
  targetType     String?
  targetId       String?
  requestBody    Json?
  responseStatus Int?
  outcome        String?
  errorMessage   String?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([outcome, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([createdAt])
}

model LoginLog {
  id           String   @id @default(cuid())
  userId       String?
  email        String?
  username     String?
  method       String
  success      Boolean
  failureReason String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([username, createdAt])
  @@index([method, success, createdAt])
  @@index([ip, createdAt])
}

model ModelPrice {
  id                      String   @id @default(cuid())
  model                   String
  upstreamProvider        String   @default("default")
  currency                String   @default("USD")
  upstreamInputPer1MTok   Decimal  @db.Decimal(18, 8)
  upstreamOutputPer1MTok  Decimal  @db.Decimal(18, 8)
  upstreamCachedInputPer1MTok Decimal @default(0) @db.Decimal(18, 8)
  upstreamPriceMultiplier Decimal @default(1) @db.Decimal(18, 8)
  customerInputPer1MTok   Decimal  @db.Decimal(18, 8)
  customerOutputPer1MTok  Decimal  @db.Decimal(18, 8)
  customerCachedInputPer1MTok Decimal @default(0) @db.Decimal(18, 8)
  customerPriceMultiplier Decimal @default(1) @db.Decimal(18, 8)
  minimumChargeUsd        Decimal  @default(0) @db.Decimal(18, 8)
  enabled                 Boolean  @default(true)
  priceVersion            String   @default("v1")
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  createdByUserId         String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  createdBy User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([enabled])
  @@index([upstreamProvider, enabled])
  @@index([priceVersion])
  @@index([effectiveFrom, effectiveTo])
  @@index([createdByUserId])
  @@unique([upstreamProvider, model])
}

model ModelPool {
  id                     String             @id @default(cuid())
  model                  String
  tierId                 String?
  status                 String             @default("ACTIVE")
  autoHealthCheckEnabled Boolean            @default(true)
  healthCheckEndpoint    String             @default("responses")
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @default(now()) @updatedAt

  tier     AccessTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  channels ModelPoolChannel[]

  @@index([status])
  @@index([tierId])
  @@index([autoHealthCheckEnabled])
  @@unique([model, tierId])
}

model DedicatedRouteRule {
  id                    String                   @id @default(cuid())
  name                  String
  targetType            DedicatedRouteTargetType
  userId                String?
  apiKeyId              String?
  ipPattern             String?
  accessTierId          String
  upstreamProvider      String?
  upstreamProviderKeyId String?
  status                DedicatedRouteRuleStatus @default(ACTIVE)
  priority              Int                      @default(100)
  startsAt              DateTime?
  expiresAt             DateTime?
  remark                String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                User?                @relation("DedicatedRouteRuleUser", fields: [userId], references: [id], onDelete: Cascade)
  apiKey              ApiKey?              @relation("DedicatedRouteRuleApiKey", fields: [apiKeyId], references: [id], onDelete: Cascade)
  accessTier          AccessTier           @relation(fields: [accessTierId], references: [id], onDelete: Restrict)
  upstreamProviderKey UpstreamProviderKey?  @relation(fields: [upstreamProviderKeyId], references: [id], onDelete: SetNull)
  apiRequests         ApiRequest[]

  @@index([targetType, status, priority])
  @@index([userId, status, priority])
  @@index([apiKeyId, status, priority])
  @@index([ipPattern, status, priority])
  @@index([status, startsAt, expiresAt])
  @@index([accessTierId])
  @@index([upstreamProviderKeyId])
}

model IpAccessTierRule {
  id        String                   @id @default(cuid())
  cidrOrIp  String
  tierId    String
  status    DedicatedRouteRuleStatus @default(ACTIVE)
  priority  Int                      @default(100)
  remark    String?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  tier AccessTier @relation(fields: [tierId], references: [id], onDelete: Restrict)

  @@index([status, priority])
  @@index([tierId])
  @@unique([cidrOrIp])
}

model ModelPoolChannel {
  id                  String    @id @default(cuid())
  modelPoolId         String
  upstreamProvider    String
  status              String    @default("ACTIVE")
  priority            Int       @default(100)
  consecutiveFailures Int       @default(0)
  recoverySuccesses   Int       @default(0)
  penalizedUntil      DateTime?
  penaltyReason       String?
  lastCheckStatus     String?
  lastCheckedAt       DateTime?
  lastSuccessfulCallAt DateTime?
  lastLatencyMs       Int?
  lastFirstTokenLatencyMs Int?
  lastError           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now()) @updatedAt

  modelPool ModelPool @relation(fields: [modelPoolId], references: [id], onDelete: Cascade)

  @@unique([modelPoolId, upstreamProvider])
  @@index([upstreamProvider, status])
  @@index([status, priority])
  @@index([penalizedUntil])
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UpstreamProvider {
  id          String                 @id @default(cuid())
  name        String                 @unique
  baseUrl     String
  apiKey      String
  status      UpstreamProviderStatus @default(ACTIVE)
  priority    Int                    @default(100)
  timeoutMs   Int                    @default(180000)
  compactItemType String             @default("compaction_summary")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  keys UpstreamProviderKey[]
}

model UpstreamProviderKey {
  id                 String   @id @default(cuid())
  upstreamProviderId String
  name               String
  key                String
  encryptedKey       String?
  encryptionKeyVersion String?
  keyPrefix          String
  status             String   @default("ACTIVE")
  priority           Int      @default(100)
  lastUsedAt         DateTime?
  lastCheckStatus    String?
  lastCheckedAt      DateTime?
  lastError          String?
  dailyLimitUsd      Decimal? @db.Decimal(18, 8)
  monthlyLimitUsd    Decimal? @db.Decimal(18, 8)
  providerRateLimit  Int?
  disabledReason     String?
  lastErrorCategory  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  upstreamProvider UpstreamProvider @relation(fields: [upstreamProviderId], references: [id], onDelete: Cascade)
  apiRequests      ApiRequest[]
  dedicatedRouteRules DedicatedRouteRule[]

  @@index([upstreamProviderId, status, priority])
  @@index([lastUsedAt])
  @@index([encryptionKeyVersion])
  @@index([lastErrorCategory])
  @@unique([upstreamProviderId, name])
}

model RedeemCode {
  id              String             @id @default(cuid())
  codeHash        String             @unique
  codePrefix      String
  amount          Decimal            @db.Decimal(18, 8)
  currency        String             @default("USD")
  status          RedeemCodeStatus   @default(ACTIVE)
  maxRedemptions  Int                @default(1)
  redeemedCount   Int                @default(0)
  expiresAt       DateTime?
  createdByUserId String?
  remark          String?
  campaignName    String?
  validUserTierId String?
  perUserLimit    Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  redemptions RedeemCodeRedemption[]
  validUserTier AccessTier?          @relation(fields: [validUserTierId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([codePrefix])
  @@index([campaignName])
  @@index([validUserTierId])
}

model RedeemCodeRedemption {
  id           String     @id @default(cuid())
  redeemCodeId String
  userId       String
  amount       Decimal    @db.Decimal(18, 8)
  createdAt    DateTime   @default(now())

  redeemCode RedeemCode @relation(fields: [redeemCodeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([redeemCodeId, createdAt])
}
